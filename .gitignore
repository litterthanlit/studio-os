.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.windsurf/
.zencoder/
skills/
skills-lock.json
.gstack/
